# Database
DATABASE_URL="postgresql://zynqo:zynqo@localhost:5433/zynqo"

# Redis
REDIS_URL="redis://localhost:6379"

# FazerCards (https://reseller.fazercards.com)
FAZER_API_KEY=""
# Секрет из панели: Settings → Webhooks → создать endpoint → URL см. /admin/settings
FAZER_WEBHOOK_SECRET=""
FAZER_API_BASE_URL="https://api.fzr.cards/api/v2"

# Freekassa (https://docs.freekassa.net)
FREEKASSA_MERCHANT_ID=""
FREEKASSA_SECRET_1=""
FREEKASSA_SECRET_2=""
# URL для заявки (prod): см. /admin/settings → Freekassa
#   Оповещение:  {APP_URL}/api/payments/freekassa/notify  (POST)
#   Успех:       {APP_URL}/payment/success               (GET)
#   Неудача:     {APP_URL}/payment/fail                  (GET)

# App
APP_URL="http://localhost:3000"

# Цены: USD_RUB_RATE — курс для пересчёта опта (не наценка)
USD_RUB_RATE=92
DEFAULT_MARKUP_PCT=10
STEAM_COMMISSION_PCT=5

ADMIN_JWT_SECRET="change-me-in-production"
# Одноразовое создание первого админа: POST /api/admin/auth/bootstrap
ADMIN_BOOTSTRAP_SECRET="change-me-bootstrap"

# Email (Resend — https://resend.com, бесплатный тариф для старта)
# Подключите домен zynqo.ru в Resend → DNS записи → отправка с noreply@zynqo.ru
RESEND_API_KEY=""
EMAIL_FROM="Zynqo <noreply@zynqo.ru>"

# SEO: Яндекс.Вебмастер / Google Search Console — код verification из HTML-тега
YANDEX_VERIFICATION=""
GOOGLE_SITE_VERIFICATION=""
