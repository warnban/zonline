generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderType {
  STEAM
  TELEGRAM_STARS
  TELEGRAM_PREMIUM
  GIFT_CARD
  TOPUP
  GAME_KEY
  STEAM_GIFT
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders  Order[]
  tickets SupportTicket[]
}

model Order {
  id              String      @id @default(cuid())
  publicId        String      @unique
  email           String
  type            OrderType
  status          OrderStatus @default(PENDING_PAYMENT)
  amountRub       Decimal     @db.Decimal(12, 2)
  amountUsd       Decimal     @db.Decimal(12, 4)
  fazerOrderId    String?
  idempotencyKey  String      @unique
  deliveryData    Json?
  metadata        Json?
  errorMessage    String?
  userId          String?
  paymentId       String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?

  user    User?    @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id               String        @id @default(cuid())
  freekassaOrderId String?       @unique
  amount           Decimal       @db.Decimal(12, 2)
  status           PaymentStatus @default(PENDING)
  callbackData     Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order Order?
}

model SupportTicket {
  id           String       @id @default(cuid())
  guestEmail   String?
  guestName    String?
  guestPhone   String?
  subject      String?
  status       TicketStatus @default(OPEN)
  accessToken  String       @unique @default(cuid())
  userId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user     User?             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@index([status])
  @@index([guestEmail])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String
  event     String
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([source, event])
  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model CatalogCategory {
  id          String   @id
  type        String
  name        String
  slug        String   @unique
  imageUrl    String?
  enabled     Boolean  @default(true)
  markupPct   Decimal? @db.Decimal(5, 2)
  sortOrder   Int      @default(0)
  syncedAt    DateTime @default(now())
  rawData     Json?

  @@index([type, enabled])
}
